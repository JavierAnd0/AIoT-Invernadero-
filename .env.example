# ============================================================
# AIoT Greenhouse — Variables de entorno
# Copiar este archivo a .env y rellenar los valores reales
# NUNCA commitear .env al repositorio
# ============================================================

# ── Base de datos PostgreSQL ─────────────────────────────────
POSTGRES_USER=greenhouse
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=greenhouse_dev

# ── Spring Boot ──────────────────────────────────────────────
# URL de conexión a PostgreSQL (solo para desarrollo local sin Docker)
DATABASE_URL=jdbc:postgresql://localhost:5432/greenhouse_dev
DB_USERNAME=greenhouse
DB_PASSWORD=change_me_strong_password

# Comportamiento JPA: update | validate | create-drop
JPA_DDL_AUTO=update

# Puerto del backend Spring Boot
BACKEND_PORT=8080

# ── Seguridad JWT ────────────────────────────────────────────
# Mínimo 256 bits — generar con: openssl rand -base64 64
JWT_SECRET=change_me_to_a_very_long_random_secret_key_minimum_256_bits_required
JWT_EXPIRATION_MS=86400000

# ── OAuth2 Google ────────────────────────────────────────────
# Obtener en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── URLs ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Módulo AI (predicciones) ─────────────────────────────────
# Ruta al script predict_cli.py relativa al directorio de trabajo del JAR
AI_SCRIPT_PATH=../ai/predict_cli.py
# Comando de Python en el sistema (python3 en Linux/Mac, python en Windows)
PYTHON_CMD=python3

# ── Simulador IoT ────────────────────────────────────────────
SIMULATOR_ENABLED=true
SIMULATOR_INTERVAL_MS=15000

# ── Frontend (Vite) ──────────────────────────────────────────
VITE_API_URL=/api/v1
