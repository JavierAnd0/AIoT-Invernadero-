FLASK_APP=app.py
FLASK_ENV=development

# Security
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/greenhouse_dev

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# AI module path (relative to backend/)
AI_MODELS_PATH=../ai/models
DEFAULT_MODEL=random_forest

# IoT simulator interval in seconds
SIMULATOR_INTERVAL=15

# OAuth2 Google
GOOGLE_CLIENT_ID=TU_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=TU_CLIENT_SECRET
FRONTEND_URL=https://a-io-t-invernadero.vercel.app
# FRONTEND_URL=http://localhost:5173   # desarrollo local
PREFERRED_URL_SCHEME=https
# PREFERRED_URL_SCHEME=http            # si no tienes SSL en DokPloy
